{
  "name": "dyna-mo-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "prepare:data": "tsx scripts/prepare-static-data.ts",
    "dev": "tsx scripts/prepare-static-data.ts && vite dev --host 127.0.0.1 --port 3000",
    "build": "tsx scripts/prepare-static-data.ts && vite build && tsx scripts/post-build.ts",
    "preview": "vite preview --host 127.0.0.1 --port 3000",
    "start": "vite preview --host 0.0.0.0 --port 3000",
    "import:csv": "tsx scripts/prepare-static-data.ts",
    "lint": "eslint src scripts tests --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-e2e.ps1",
    "screenshots": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-e2e.ps1 tests/e2e/smoke.spec.ts --project=chromium",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.0",
    "lucide-react": "^1.17.0",
    "next": "14.2.30",
    "next-themes": "^0.4.6",
    "ngl": "^2.4.0",
    "plotly.js-dist-min": "^3.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-plotly.js": "^2.6.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/plotly.js": "^3.0.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-plotly.js": "^2.6.4",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.30",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "playwright": "^1.60.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
